{
  "name": "quick-tools",
  "version": "1.0.0",
  "description": "快捷工具 - 链接、文件夹、按钮、待办一体化桌面工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.quicktools.app",
    "productName": "快捷工具",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "files": ["dist/**/*", "electron/**/*"]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
